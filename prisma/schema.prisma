// Sightline — Prisma schema
// Phase 0: identity & tenancy (Profile, Organization, Membership).
// Phase 1: the core loop (Competitor, Source, SourceSnapshot, Change,
//          IntelChunk, AiRun).
//
// Multi-tenancy: every domain table carries a scalar `org_id`. We deliberately
// do NOT model an Organization relation on domain tables — Prisma connects as a
// privileged role that bypasses RLS, so isolation here is enforced in app code
// (see src/lib/org-scope.ts) by always filtering on the resolved org_id. The
// `intel_chunks.embedding` pgvector column and all RLS live in
// prisma/sql/0002_phase1.sql.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  owner
  admin
  member
  viewer
}

/// A user profile, 1:1 with a Supabase auth.users row.
/// `id` equals auth.users.id; rows are created by a DB trigger on signup.
model Profile {
  id        String   @id @db.Uuid
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships Membership[]

  @@map("profiles")
}

/// A tenant. Every domain table in later phases carries `org_id`.
model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships Membership[]

  @@map("organizations")
}

/// Join table: which user belongs to which org, and with what role.
model Membership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role     @default(member)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────
// Phase 1 — the core loop
// ─────────────────────────────────────────────────────────────

enum SourceType {
  pricing
  changelog
  blog
  news
  careers
  custom
}

enum ChangeCategory {
  pricing
  product
  positioning
  hiring
  funding
  other
}

enum ImpactLevel {
  low
  medium
  high
}

enum ChangeStatus {
  new
  reviewed
  dismissed
  promoted
}

enum AiRunType {
  change_analyze
  ask
  embed
  digest
  battlecard_suggest
}

/// A competitor an org is tracking.
model Competitor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  domain    String?
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sources Source[]
  changes Change[]

  @@index([orgId])
  @@map("competitors")
}

/// A monitored public page belonging to a competitor.
model Source {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String     @map("org_id") @db.Uuid
  competitorId  String     @map("competitor_id") @db.Uuid
  type          SourceType
  url           String
  // Phase 2: scheduled monitoring. "daily" | "weekly" | "manual" (never auto).
  // Defaults to daily; a 12h hard floor is enforced in code regardless.
  scanFrequency String     @default("daily") @map("scan_frequency")
  isActive      Boolean    @default(true) @map("is_active")
  lastScannedAt DateTime?  @map("last_scanned_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  competitor Competitor       @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  snapshots  SourceSnapshot[]
  changes    Change[]

  @@index([orgId])
  @@index([competitorId])
  @@map("sources")
}

/// A point-in-time capture of a source's normalized content.
model SourceSnapshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  sourceId    String   @map("source_id") @db.Uuid
  contentText String   @map("content_text")
  contentHash String   @map("content_hash")
  rawUrl      String?  @map("raw_url")
  fetchedAt   DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([sourceId, fetchedAt(sort: Desc)])
  @@map("source_snapshots")
}

/// A meaningful, AI-summarized change detected between two snapshots.
model Change {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  competitorId     String         @map("competitor_id") @db.Uuid
  sourceId         String         @map("source_id") @db.Uuid
  summary          String
  whyItMatters     String         @map("why_it_matters")
  category         ChangeCategory
  impact           ImpactLevel
  confidence       Float
  diffExcerpt      String?        @map("diff_excerpt")
  snapshotBeforeId String?        @map("snapshot_before_id") @db.Uuid
  snapshotAfterId  String?        @map("snapshot_after_id") @db.Uuid
  status           ChangeStatus   @default(new)
  detectedAt       DateTime       @default(now()) @map("detected_at") @db.Timestamptz(6)

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  source     Source     @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([orgId, detectedAt(sort: Desc)])
  @@index([competitorId])
  @@map("changes")
}

/// A chunk of collected intel, embedded for RAG retrieval.
///
/// `embedding` is a pgvector column (not a native Prisma type), so it is modeled
/// as `Unsupported("vector(1536)")?`. This is intentional and load-bearing:
///   - it makes Prisma aware the column EXISTS, so `prisma db push` / migrate
///     will NOT drop it (and will not warn about data loss);
///   - Prisma leaves the column's HNSW index (created in 0002_phase1.sql) alone,
///     because it can't manage indexes on Unsupported columns;
///   - the field is omitted from the generated client — we read/write it via
///     raw SQL ($queryRawUnsafe / $executeRawUnsafe) in src/lib/ai/ask.ts and
///     src/lib/scan.ts, which is unchanged.
/// The column + index are still defined in prisma/sql/0002_phase1.sql for fresh
/// databases.
model IntelChunk {
  id               String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String                       @map("org_id") @db.Uuid
  competitorId     String                       @map("competitor_id") @db.Uuid
  sourceSnapshotId String                       @map("source_snapshot_id") @db.Uuid
  content          String
  embedding        Unsupported("vector(1536)")?
  createdAt        DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId])
  @@map("intel_chunks")
}

/// Audit + cost record for every AI call (decision-support, measurable).
model AiRun {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  type         AiRunType
  model        String
  inputTokens  Int       @default(0) @map("input_tokens")
  outputTokens Int       @default(0) @map("output_tokens")
  costUsd      Decimal   @default(0) @map("cost_usd") @db.Decimal(12, 6)
  latencyMs    Int       @default(0) @map("latency_ms")
  status       String    @default("success")
  traceId      String?   @map("trace_id")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, createdAt(sort: Desc)])
  @@map("ai_runs")
}

// ─────────────────────────────────────────────────────────────
// Phase 2 — scheduled monitoring artifacts
// ─────────────────────────────────────────────────────────────

/// A per-org weekly summary of detected changes (in-app digest).
model Digest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd   DateTime @map("period_end") @db.Timestamptz(6)
  summary     String
  changeCount Int      @default(0) @map("change_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([orgId, periodStart])
  @@index([orgId, periodEnd(sort: Desc)])
  @@map("digests")
}

// ─────────────────────────────────────────────────────────────
// Phase 3 — collaboration (battlecards, comments, assignments)
// ─────────────────────────────────────────────────────────────

enum BattlecardStatus {
  draft
  published
}

enum CommentTarget {
  change
  battlecard
}

enum AssignmentStatus {
  open
  done
}

enum SuggestionStatus {
  pending
  approved
  rejected
}

/// One collaborative battlecard per competitor. The document body lives in a
/// Liveblocks/Yjs room (`roomId`); the DB holds metadata only. `roomId` is
/// org-namespaced for tenant isolation (see src/lib/liveblocks/rooms.ts).
model Battlecard {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  competitorId String           @map("competitor_id") @db.Uuid
  title        String
  roomId       String           @unique @map("room_id")
  status       BattlecardStatus @default(draft)
  updatedById  String?          @map("updated_by_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  suggestions BattlecardSuggestion[]

  @@unique([orgId, competitorId])
  @@index([orgId])
  @@map("battlecards")
}

/// A comment on a change or a battlecard.
model Comment {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String        @map("org_id") @db.Uuid
  targetType CommentTarget @map("target_type")
  targetId   String        @map("target_id") @db.Uuid
  authorId   String        @map("author_id") @db.Uuid
  body       String
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, targetType, targetId, createdAt])
  @@map("comments")
}

/// Assignment of a change to a teammate. One active assignment per change.
model Assignment {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  changeId     String           @unique @map("change_id") @db.Uuid
  assigneeId   String           @map("assignee_id") @db.Uuid
  assignedById String?          @map("assigned_by_id") @db.Uuid
  status       AssignmentStatus @default(open)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, assigneeId])
  @@map("assignments")
}

/// A pending, AI-drafted battlecard edit produced from a high-impact change.
/// NEVER auto-applied — a human approves (applies in the editor) or rejects.
model BattlecardSuggestion {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  battlecardId String           @map("battlecard_id") @db.Uuid
  competitorId String           @map("competitor_id") @db.Uuid
  changeId     String?          @map("change_id") @db.Uuid
  content      String
  status       SuggestionStatus @default(pending)
  resolvedById String?          @map("resolved_by_id") @db.Uuid
  resolvedAt   DateTime?        @map("resolved_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  battlecard Battlecard @relation(fields: [battlecardId], references: [id], onDelete: Cascade)

  @@index([orgId, battlecardId, status])
  @@map("battlecard_suggestions")
}

// ─────────────────────────────────────────────────────────────
// Phase 4 — business (billing) + eval/feedback
// ─────────────────────────────────────────────────────────────

enum Plan {
  free
  pro
  team
}

enum FeedbackRating {
  up
  down
}

/// One billing record per org, synced from Stripe via webhooks. Prisma writes
/// it server-side (RLS-bypassing); the app reads it to gate features by plan.
model Subscription {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                String    @unique @map("org_id") @db.Uuid
  plan                 Plan      @default(free)
  status               String    @default("none")
  seats                Int       @default(1)
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("subscriptions")
}

/// Human feedback on AI output (eval loop): thumbs + optional correction, on an
/// Ask answer (ai_run) or a change summary (change). One vote per user/target.
model AiFeedback {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  rating          FeedbackRating
  correctedOutput String?        @map("corrected_output")
  aiRunId         String?        @map("ai_run_id") @db.Uuid
  changeId        String?        @map("change_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([changeId, userId])
  @@unique([aiRunId, userId])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("ai_feedback")
}

// ─────────────────────────────────────────────────────────────
// Phase 5 — audit log (senior hardening)
// ─────────────────────────────────────────────────────────────

/// Append-only record of significant org actions (who did what, to what, when).
/// Written server-side, read by an owner/admin-only UI. Org-scoped + RLS.
model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  target    String?
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, createdAt(sort: Desc)])
  @@map("audit_log")
}
