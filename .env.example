# ─────────────────────────────────────────────────────────────
# Sightline — environment template (Phase 0)
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Supabase (public, safe to expose to the browser) ---
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
# Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Supabase (server-only, NEVER expose to the browser) ---
# Project Settings → API → Project API keys → service_role
# Used only inside server code AFTER org_id has been resolved & verified.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Database (Prisma) ---
# Project Settings → Database → Connection string.
# DATABASE_URL = pooled connection (PgBouncer, port 6543) for the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = direct connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Phase 1 — external services (server-only, NEVER expose to the browser)
# ─────────────────────────────────────────────────────────────

# --- AI: reasoning (Anthropic via Vercel AI SDK) ---
# Used for change summaries and Ask Sightline answers. console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
# Optional override; defaults in code to claude-opus-4-8 if unset.
ANTHROPIC_MODEL="claude-opus-4-8"

# --- AI: embeddings ONLY (OpenAI text-embedding-3-small) ---
# OPTIONAL. Never used as a chat/answer model — embeddings for pgvector
# retrieval only. If unset (or out of quota), scans still work fully; only
# Ask Sightline RAG is disabled until a key with balance is provided.
OPENAI_API_KEY="sk-proj-your-openai-key"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Web fetching (Firecrawl) ---
# Fetches + normalizes public competitor pages. firecrawl.dev
FIRECRAWL_API_KEY="fc-your-firecrawl-key"
