# ─────────────────────────────────────────────────────────────
# Sightline — environment template (Phase 0)
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Supabase (public, safe to expose to the browser) ---
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
# Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Supabase (server-only, NEVER expose to the browser) ---
# Project Settings → API → Project API keys → service_role
# Used only inside server code AFTER org_id has been resolved & verified.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Database (Prisma) ---
# Project Settings → Database → Connection string.
# DATABASE_URL = pooled connection (PgBouncer, port 6543) for the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = direct connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Phase 1 — external services (server-only, NEVER expose to the browser)
# ─────────────────────────────────────────────────────────────

# --- AI: reasoning (Anthropic via Vercel AI SDK) ---
# Used for change summaries and Ask Sightline answers. console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
# Optional override; defaults in code to claude-opus-4-8 if unset.
ANTHROPIC_MODEL="claude-opus-4-8"
# Cheaper model for lower-stakes structured calls (change classification,
# battlecard drafts) — multi-model routing to cut cost. Defaults to haiku.
ANTHROPIC_FAST_MODEL="claude-haiku-4-5"

# --- AI: embeddings ONLY (OpenAI text-embedding-3-small) ---
# OPTIONAL. Never used as a chat/answer model — embeddings for pgvector
# retrieval only. If unset (or out of quota), scans still work fully; only
# Ask Sightline RAG is disabled until a key with balance is provided.
OPENAI_API_KEY="sk-proj-your-openai-key"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Web fetching (Firecrawl) ---
# Fetches + normalizes public competitor pages. firecrawl.dev
FIRECRAWL_API_KEY="fc-your-firecrawl-key"

# ─────────────────────────────────────────────────────────────
# Phase 2 — background jobs + observability
# ─────────────────────────────────────────────────────────────

# --- Inngest (scheduled monitoring, durable jobs) ---
# Local dev needs NO keys (use `npx inngest-cli dev`). Required in production.
# Dashboard: app.inngest.com → your app → Keys.
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="signkey-prod-your-inngest-signing-key"

# --- Langfuse (LLM tracing/cost/latency) ---
# OPTIONAL. If unset, tracing is a no-op and ai_runs logging is unaffected.
# cloud.langfuse.com → Settings → API Keys.
LANGFUSE_SECRET_KEY="sk-lf-your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="pk-lf-your-langfuse-public-key"
LANGFUSE_BASEURL="https://cloud.langfuse.com"

# ─────────────────────────────────────────────────────────────
# Phase 3 — real-time collaboration
# ─────────────────────────────────────────────────────────────

# --- Liveblocks (collaborative battlecards: presence, cursors, Yjs) ---
# Server-only secret key. The browser never sees it — clients authenticate via
# our /api/liveblocks-auth route, which grants access ONLY to the user's own
# org rooms. liveblocks.io → your project → API keys (secret key, sk_...).
LIVEBLOCKS_SECRET_KEY="sk_your-liveblocks-secret-key"

# ─────────────────────────────────────────────────────────────
# Phase 4 — billing (Stripe, TEST MODE ONLY)
# ─────────────────────────────────────────────────────────────

# OPTIONAL. Use TEST keys only (sk_test_…). If unset, billing shows a clean
# "billing unavailable" notice and every org is treated as the free plan.
# dashboard.stripe.com (Test mode) → Developers → API keys.
STRIPE_SECRET_KEY="sk_test_your-stripe-test-secret-key"
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` prints this.
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-signing-secret"
# Recurring per-seat prices (Products → add price). Pro and Team tiers.
STRIPE_PRO_PRICE_ID="price_your_pro_per_seat_price_id"
STRIPE_TEAM_PRICE_ID="price_your_team_per_seat_price_id"
# Metered (usage-based) price backed by a Billing Meter, for AI usage on top.
STRIPE_AI_USAGE_PRICE_ID="price_your_metered_ai_usage_price_id"
# The event_name configured on that meter (Billing → Meters).
STRIPE_AI_USAGE_METER_EVENT="ai_answer"

# ─────────────────────────────────────────────────────────────
# Phase 5 — senior hardening
# ─────────────────────────────────────────────────────────────

# --- Rate limiting + response cache (Upstash Redis) ---
# OPTIONAL. When unset, the limiter + answer cache fall back to in-memory
# (fine for a single instance/dev). For production/serverless, create a free
# Upstash Redis DB → console.upstash.com → REST API.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# --- Playwright e2e (opt-in core loop) ---
# Set these to run the full signed-in core-loop spec against a seeded deploy:
#   E2E_BASE_URL=https://your-preview.vercel.app E2E_EMAIL=… E2E_PASSWORD=… \
#   npx playwright test --project=core-loop
# (The CI "smoke" project needs none of these.)
# E2E_BASE_URL=""
# E2E_EMAIL=""
# E2E_PASSWORD=""
