# ─────────────────────────────────────────────────────────────
# Sightline — environment template (Phase 0)
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Supabase (public, safe to expose to the browser) ---
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
# Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Supabase (server-only, NEVER expose to the browser) ---
# Project Settings → API → Project API keys → service_role
# Used only inside server code AFTER org_id has been resolved & verified.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Database (Prisma) ---
# Project Settings → Database → Connection string.
# DATABASE_URL = pooled connection (PgBouncer, port 6543) for the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = direct connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
